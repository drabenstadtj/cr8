# System
PUID=1000
PGID=1000
TZ=America/New_York

# Paths
CONFIG_PATH=/opt/data/config
MUSIC_PATH=/mnt/data/music
DOWNLOAD_DIR=./downloads

# cr8
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# cr8 ↔ Explo (shared API key — set the same value in both)
EXPLO_API_KEY=

# Gonic
GONIC_URL=http://gonic:4747
GONIC_PUBLIC_URL=https://listen.example.com
GONIC_USER=admin
GONIC_PASSWORD=

# slskd
SLSKD_URL=http://slskd:5030
SLSKD_API_KEY=

# betanin (optional)
BETANIN_URL=
BETANIN_API_KEY=

# cr8 frontend URL (for CORS — only needed if not using the default)
# FRONTEND_URL=http://localhost:5173
