PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
NODE_ENV=production

# SQLite (Docker uses /data/cr8.db, dev uses file:./dev.db)
DATABASE_URL="file:./dev.db"

# slskd
SLSKD_URL=http://your-slskd-host:5030
SLSKD_API_KEY=

# betanin (optional — triggers beets import when download completes)
BETANIN_URL=http://your-betanin-host:9393
BETANIN_API_KEY=

# Gonic
GONIC_URL=http://your-gonic-host:4747
GONIC_PUBLIC_URL=https://listen.example.com
GONIC_USER=admin
GONIC_PASSWORD=

# URL of the frontend (for CORS)
FRONTEND_URL=http://localhost:5173

# Where completed downloads are dropped (beets watched folder)
DOWNLOAD_DIR=/downloads

# Admin account created on first boot
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# API key for Explo to fetch per-user ListenBrainz usernames
EXPLO_API_KEY=
