PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
NODE_ENV=production

# SQLite (Docker uses /data/cr8.db, dev uses file:./dev.db)
DATABASE_URL="file:./dev.db"

# slskd
SLSKD_URL=http://your-slskd-host:5030
SLSKD_API_KEY=

# Navidrome
NAVIDROME_URL=http://your-navidrome-host:4533
NAVIDROME_PUBLIC_URL=https://listen.example.com
NAVIDROME_USER=admin
NAVIDROME_PASSWORD=

# URL of the frontend (for CORS)
FRONTEND_URL=http://localhost:5173

# Where completed downloads are dropped (beets watched folder)
DOWNLOAD_DIR=/downloads

# Admin account created on first boot
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
